{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proofdesk.local/schemas/proofdesk-manifest.schema.json",
  "title": "ProofDesk Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "generated_at",
    "latest_snapshot",
    "latest_event_seq",
    "latest_update_seq",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]{3,64}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "latest_snapshot": {
      "type": "string",
      "pattern": "^PD_STATE_[0-9]{8}T[0-9]{6}Z_[a-f0-9]{7,12}\\.json$"
    },
    "latest_event_seq": {
      "type": "integer",
      "minimum": 0
    },
    "latest_update_seq": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "file",
          "sha256",
          "created_at"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "snapshot",
              "event",
              "update"
            ]
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "supersedes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
